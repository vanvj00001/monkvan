// 生成search.json
{{ $searchData := dict "pages" slice }}
{{ range .Site.Pages }}
    {{ if and (ne .Type "search") (ne .Kind "section") }}
        {{ $pageData := dict 
            "title" .Title
            "url" .Permalink
            "content" .Plain 
            "summary" .Summary
        }}
        {{ $searchData.pages = $searchData.pages | append $pageData }}
    {{ end }}
{{ end }}
{{ $searchData | jsonify }}
